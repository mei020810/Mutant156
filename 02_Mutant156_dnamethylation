#!/bin/bash
set -euo pipefail
ALIGNDIR="02.align"
OUT="QC/QC_summary_v4.tsv"

printf "sample\tmapping_eff_pct\tdup_pct\talignments_analysed\tdedup_leftover\n" > "$OUT"

# 提取 “: 后面的数字/百分比”，并去掉逗号、空格、TAB
pct_after_colon () {
  local pat="$1" file="$2"
  perl -ne '
    my $pat=shift;
    if (/$pat/ && /:\s*([0-9.]+)%/) { print "$1\n"; exit }
  ' "$pat" "$file" 2>/dev/null || true
}

pct_in_parens () {
  local pat="$1" file="$2"
  perl -ne '
    my $pat=shift;
    if (/$pat/ && /\(([0-9.]+)%\)/) { print "$1\n"; exit }
  ' "$pat" "$file" 2>/dev/null || true
}

int_after_last_colon () {
  local pat="$1" file="$2"
  perl -ne '
    my $pat=shift;
    if (/$pat/ && /\:\s*([0-9][0-9,]*)\s*$/) { my $x=$1; $x=~s/,//g; print "$x\n"; exit }
  ' "$pat" "$file" 2>/dev/null || true
}

leftover_count () {
  local file="$1"
  perl -ne '
    if(/Total count of deduplicated leftover sequences:\s*([0-9][0-9,]*)/) {
      my $x=$1; $x=~s/,//g; print "$x\n"; exit
    }
  ' "$file" 2>/dev/null || true
}

for sdir in ${ALIGNDIR}/*; do
  [[ -d "$sdir" ]] || continue
  s=$(basename "$sdir")

  pe=$(ls -1 "$sdir"/*_PE_report.txt 2>/dev/null | head -n 1 || true)
  dedup=$(ls -1 "$sdir"/*deduplication_report.txt 2>/dev/null | head -n 1 || true)

  map="NA"
  [[ -n "$pe" ]] && map=$(pct_after_colon "Mapping efficiency" "$pe")
  [[ -z "$map" ]] && map="NA"

  dup="NA"; analysed="NA"; left="NA"
  if [[ -n "$dedup" ]]; then
    dup=$(pct_in_parens "Total number duplicated alignments removed" "$dedup"); [[ -z "$dup" ]] && dup="NA"
    analysed=$(int_after_last_colon "Total number of alignments analysed" "$dedup"); [[ -z "$analysed" ]] && analysed="NA"
    left=$(leftover_count "$dedup"); [[ -z "$left" ]] && left="NA"
  fi

  printf "%s\t%s\t%s\t%s\t%s\n" "$s" "$map" "$dup" "$analysed" "$left" >> "$OUT"
done

echo "[OK] wrote $OUT"
EOF

