#!/bin/bash
set -euo pipefail
THREADS=12
GENOME="./bismark_index"
ALIGNDIR="02.align"
OUTLOG="logs"
mkdir -p "$OUTLOG"

SAMPLES=(156_big_1 156_big_2 156_small_1 156_small_2 W82_1 W82_2)

BUFFER_SIZE="50G"
COV_THRESHOLD=3

for s in "${SAMPLES[@]}"; do
  echo "=== $s methylation extractor: $(date) ==="

  DEDUP_BAM=$(ls -1 ${ALIGNDIR}/${s}/*deduplicated.bam | head -n 1)

#  双端测序、忽略read1和read2的前2个碱基、内存缓冲区大小为50G、只分析CX上下文（CG/CHG/CHH，H=A/T/C，植物甲基化分析核心参数）、过滤覆盖度＜3的位点、生成全面的甲基化报告、生成bedGraph格式文件，并压缩为.gz格式、指定并行线程数、指定基因组索引目录
  bismark_methylation_extractor \
    --paired-end \
    --ignore 2 --ignore_r2 2 \
    --buffer_size "${BUFFER_SIZE}" \
    --CX_context \
    --cutoff "${COV_THRESHOLD}" \
    --comprehensive \
    --bedGraph --gzip \
    --parallel "${THREADS}" \
    --genome_folder "${GENOME}" \
    --output "${ALIGNDIR}/${s}" \
    "${DEDUP_BAM}" \
    2> "${OUTLOG}/${s}.extractor.log"

  # 可选：生成 CX 报告（DSS/统计常用）
  COVGZ=$(ls -1 ${ALIGNDIR}/${s}/*.bismark.cov.gz | head -n 1)
  coverage2cytosine \
    "${COVGZ}" \
    --dir "${ALIGNDIR}/${s}" \
    --CX_context \
    -o "${s}" \
    --genome_folder "${GENOME}" \
    --coverage_threshold "${COV_THRESHOLD}" \
    2> "${OUTLOG}/${s}.coverage2cytosine.log"

  echo
done
EOF

