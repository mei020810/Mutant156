cat > QC/make_meth_conv_ratio_safe.sh <<'EOF'
#!/bin/bash
set -euo pipefail

OUT="QC/meth_conv_ratio_safe.tsv"
printf "sample\tCs_analysed\tCpG_meth\tCpG_conv\tCpG_unmeth_pct\tCHG_meth\tCHG_conv\tCHG_unmeth_pct\tCHH_meth\tCHH_conv\tCHH_unmeth_pct\n" > "$OUT"

for sdir in 02.align/*; do
  [[ -d "$sdir" ]] || continue
  sample=$(basename "$sdir")
  rpt=$(ls -1 "$sdir"/*deduplicated_splitting_report.txt 2>/dev/null | head -n 1 || true)
  [[ -n "$rpt" ]] || continue

  awk -v s="$sample" -F': *' '
    function clean(x){ gsub(/,/, "", x); gsub(/[ \t\r]/, "", x); return x }
    function pct(u,m){
      if ((u+m) > 0) return 100*u/(u+m);
      else return -1;
    }
    /Total number of C\x27s analysed/                { Cs=clean($2)+0 }
    /Total methylated C\x27s in CpG context/         { CpGm=clean($2)+0 }
    /Total C to T conversions in CpG context/        { CpGu=clean($2)+0 }
    /Total methylated C\x27s in CHG context/         { CHGm=clean($2)+0 }
    /Total C to T conversions in CHG context/        { CHGu=clean($2)+0 }
    /Total methylated C\x27s in CHH context/         { CHHm=clean($2)+0 }
    /Total C to T conversions in CHH context/        { CHHu=clean($2)+0 }
    END{
      CpGun=pct(CpGu,CpGm); CHGun=pct(CHGu,CHGm); CHHun=pct(CHHu,CHHm);

      printf "%s\t%d\t%d\t%d\t", s, Cs, CpGm, CpGu;
      if (CpGun<0) printf "NA\t"; else printf "%.3f\t", CpGun;

      printf "%d\t%d\t", CHGm, CHGu;
      if (CHGun<0) printf "NA\t"; else printf "%.3f\t", CHGun;

      printf "%d\t%d\t", CHHm, CHHu;
      if (CHHun<0) printf "NA\n"; else printf "%.3f\n", CHHun;
    }
  ' "$rpt" >> "$OUT"
done

echo "[OK] wrote $OUT"
EOF

