vim make_qc_deg_table.py
#!/usr/bin/env python3
import re
import os
import glob
import csv

PADJ_CUT = 0.05
LFC_CUT = 1.0

def read_text(path):
    with open(path, "r", encoding="utf-8", errors="ignore") as f:
        return f.read()

def parse_fastp_log(path):
    """
    Return dict: clean_pairs (Read1 after filtering total reads), dup_rate, insert_size
    """
    txt = read_text(path)

    m = re.search(r"Read1 after filtering:\s*?\n.*?total reads:\s*(\d+)", txt, re.S)
    clean_pairs = int(m.group(1)) if m else None

    m = re.search(r"Duplication rate:\s*([\d\.]+)%", txt)
    dup_rate = float(m.group(1)) if m else None

    m = re.search(r"Insert size peak.*?:\s*(\d+)", txt)
    insert_size = int(m.group(1)) if m else None

    return {"clean_pairs": clean_pairs, "dup_rate": dup_rate, "insert_size": insert_size}

def parse_hisat2_log(path):
    """
    Return dict: mapping_ratio, concord_exact1, concord_gt1, concord_total
    """
    txt = read_text(path)

    m = re.search(r"([\d\.]+)%\s+overall alignment rate", txt)
    mapping_ratio = float(m.group(1)) if m else None

    m1 = re.search(r"(\d+)\s+\([\d\.]+%\)\s+aligned concordantly exactly 1 time", txt)
    exact1 = int(m1.group(1)) if m1 else 0

    m2 = re.search(r"(\d+)\s+\([\d\.]+%\)\s+aligned concordantly >1 times", txt)
    gt1 = int(m2.group(1)) if m2 else 0

    concord_total = exact1 + gt1
    return {"mapping_ratio": mapping_ratio, "concord_total": concord_total}

def parse_deg_csv(path):
    """
    Return dict: sig/up/down using PADJ_CUT & |LFC|>=LFC_CUT
    """
    # DESeq2 csv: rownames are gene IDs; columns include log2FoldChange, padj
    sig = up = down = 0
    with open(path, "r", encoding="utf-8", errors="ignore") as f:
        reader = csv.DictReader(f)
        for row in reader:
            try:
                lfc = float(row.get("log2FoldChange", "nan"))
            except:
                continue
            padj_str = row.get("padj", "")
            try:
                padj = float(padj_str) if padj_str not in ("", "NA", "NaN", None) else 1.0
            except:
                padj = 1.0

            if padj < PADJ_CUT and abs(lfc) >= LFC_CUT:
                sig += 1
                if lfc > 0:
                    up += 1
                elif lfc < 0:
                    down += 1
    return {"sig": sig, "up": up, "down": down}

def main():
    logs_dir = "logs"
    deg_dir = "deseq2_out"
    out_xlsx = "Mutant_RNAseq_QC_DEG.xlsx"
    out_qc_csv = "Mapping_QC.csv"
    out_deg_csv = "DEG_summary.csv"

    # -------- Mapping/QC table (per sample) --------
    fastp_logs = {os.path.basename(p).replace(".fastp.log",""): p
                  for p in glob.glob(os.path.join(logs_dir, "*.fastp.log"))}
    hisat2_logs = {os.path.basename(p).replace(".hisat2.log",""): p
                   for p in glob.glob(os.path.join(logs_dir, "*.hisat2.log"))}

    samples = sorted(set(fastp_logs.keys()) & set(hisat2_logs.keys()))
    qc_rows = []
    for s in samples:
        fp = parse_fastp_log(fastp_logs[s])
        hs = parse_hisat2_log(hisat2_logs[s])

        clean_pairs = fp["clean_pairs"]
        concord = hs["concord_total"]
        concord_ratio = (concord / clean_pairs * 100.0) if (clean_pairs and concord) else None

        qc_rows.append({
            "Sample": s,
            "Clean_data_pairs": clean_pairs,
            "Mapping_ratio_%": hs["mapping_ratio"],
            "Aligned_concordantly_pairs": concord,
            "Concordantly_ratio_%": round(concord_ratio, 2) if concord_ratio is not None else None,
            "Duplication_rate_%": fp["dup_rate"],
            "Insert_size_peak": fp["insert_size"],
        })

    # write QC csv
    with open(out_qc_csv, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=list(qc_rows[0].keys()) if qc_rows else [])
        w.writeheader()
        for r in qc_rows:
            w.writerow(r)

    # -------- DEG summary table (per comparison) --------
    deg_files = sorted(glob.glob(os.path.join(deg_dir, "DEG_*.csv")))
    deg_rows = []
    for p in deg_files:
        name = os.path.basename(p).replace("DEG_", "").replace(".csv", "")
        stat = parse_deg_csv(p)
        deg_rows.append({
            "Comparison": name,
            "padj_cut": PADJ_CUT,
            "abs_log2FC_cut": LFC_CUT,
            "Sig_genes": stat["sig"],
            "Up_genes": stat["up"],
            "Down_genes": stat["down"],
        })

    with open(out_deg_csv, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=list(deg_rows[0].keys()) if deg_rows else [])
        w.writeheader()
        for r in deg_rows:
            w.writerow(r)

    # -------- optional: write xlsx (2 sheets) --------
    try:
        from openpyxl import Workbook
        from openpyxl.utils import get_column_letter
        from openpyxl.styles import Font, Alignment

        wb = Workbook()
        wb.remove(wb.active)

        def add_sheet(title, rows):
            ws = wb.create_sheet(title)
            if not rows:
                return
            headers = list(rows[0].keys())
            ws.append(headers)
            for r in rows:
                ws.append([r.get(h) for h in headers])

            # style
            bold = Font(bold=True)
            for c in range(1, len(headers)+1):
                ws.cell(row=1, column=c).font = bold
                ws.cell(row=1, column=c).alignment = Alignment(horizontal="center")

            ws.freeze_panes = "A2"
            # auto width (rough)
            for c, h in enumerate(headers, start=1):
                maxlen = max(len(str(h)), max(len(str(ws.cell(row=r, column=c).value or "")) for r in range(2, ws.max_row+1)))
                ws.column_dimensions[get_column_letter(c)].width = min(maxlen + 2, 40)

        add_sheet("Mapping_QC", qc_rows)
        add_sheet("DEG_summary", deg_rows)
        wb.save(out_xlsx)
        print(f"[OK] Wrote {out_xlsx} (and {out_qc_csv}, {out_deg_csv})")
    except Exception as e:
        print(f"[WARN] openpyxl not available or failed ({e}). Wrote CSV only: {out_qc_csv}, {out_deg_csv}")

if __name__ == "__main__":
    main()
