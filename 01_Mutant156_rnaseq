rm(list=ls())
suppressPackageStartupMessages({
  library(DESeq2)
  library(GenomicFeatures)
  library(rtracklayer)
  library(data.table)
})

# ===== 参数 =====
gtf_file <- "/mnt/nfs2/stu_fy/hms/RNAseq_Data/Gmax_508_Wm82/Gmax_508_Wm82.a4.v1.gene.gtf"
dds_rds  <- "deseq2_out/dds.rds"

in_expr_csv  <- "deseq2_out/Expr_normcounts_with_DEGflags.csv"
out_expr_csv <- "deseq2_out/Expr_normcounts_TPM_FPKM_with_DEGflags.csv"

# 你去后缀用的规则
clean_id <- function(x) sub("\\.Wm82\\.a4\\.v1$", "", x)

# ===== 读取 dds 和 raw counts =====
dds <- readRDS(dds_rds)
cts <- counts(dds, normalized = FALSE)   # raw fragment counts
gene_raw <- rownames(cts)
gene_clean <- clean_id(gene_raw)

# ===== 从 GTF 计算每个 gene 的 exon union length（bp）=====
message("[INFO] Building TxDb from GTF (may take a bit)...")
txdb <- makeTxDbFromGFF(gtf_file, format="gtf")

ex_by_gene <- exonsBy(txdb, by="gene")
# exon并集长度：reduce后求和
gene_len_bp <- sapply(ex_by_gene, function(gr) sum(width(reduce(gr))))
len_dt <- data.table(
  Gene_gtf = names(gene_len_bp),
  Gene_clean = clean_id(names(gene_len_bp)),
  exon_len_bp = as.numeric(gene_len_bp)
)
# 如果clean后出现重复，取最大长度
len_dt <- len_dt[, .(exon_len_bp = max(exon_len_bp, na.rm=TRUE)), by=Gene_clean]

# 对齐到counts矩阵顺序
len_map <- len_dt$exon_len_bp[match(gene_clean, len_dt$Gene_clean)]
len_kb  <- len_map / 1000

# ===== 计算 TPM / FPKM =====
# RPK = counts / length_kb
rpk <- sweep(cts, 1, len_kb, "/")
# 每列 sum(RPK)
sum_rpk <- colSums(rpk, na.rm=TRUE)

tpm  <- sweep(rpk, 2, sum_rpk, "/") * 1e6

lib_m <- colSums(cts, na.rm=TRUE) / 1e6
fpkm <- sweep(sweep(cts, 1, len_kb, "/"), 2, lib_m, "/")

# 转成 data.table，加列名前缀
tpm_dt <- as.data.table(tpm, keep.rownames = "Gene_raw")
setnames(tpm_dt, old = setdiff(names(tpm_dt), "Gene_raw"), new = paste0("TPM_", setdiff(names(tpm_dt), "Gene_raw")))

fpkm_dt <- as.data.table(fpkm, keep.rownames = "Gene_raw")
setnames(fpkm_dt, old = setdiff(names(fpkm_dt), "Gene_raw"), new = paste0("FPKM_", setdiff(names(fpkm_dt), "Gene_raw")))

len_out <- data.table(Gene = gene_raw, Gene_clean = gene_clean, exon_len_bp = len_map)

# ===== 合并到现有总表 =====
expr <- fread(in_expr_csv)

# tpm_dt/fpkm_dt 用的是 Gene_raw（dds的原始ID），与 expr$Gene 对齐
expr2 <- merge(expr, len_out, by=c("Gene","Gene_clean"), all.x=TRUE, sort=FALSE)
expr2 <- merge(expr2, tpm_dt,  by.x="Gene", by.y="Gene_raw", all.x=TRUE, sort=FALSE)
expr2 <- merge(expr2, fpkm_dt, by.x="Gene", by.y="Gene_raw", all.x=TRUE, sort=FALSE)

fwrite(expr2, out_expr_csv)
message("Done: ", out_expr_csv)
