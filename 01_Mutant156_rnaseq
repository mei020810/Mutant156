rm(list=ls())

padj_cut <- 0.05
lfc_cut  <- 1

dir.create("deseq2_out", showWarnings = FALSE)

comparisons <- list(
  M156big_vs_Wm82big    = "deseq2_out/DEG_M156big_vs_Wm82big.csv",
  M156small_vs_Wm82big  = "deseq2_out/DEG_M156small_vs_Wm82big.csv",
  M156small_vs_M156big  = "deseq2_out/DEG_M156small_vs_M156big.csv"
)

summary_list <- list()

for (cmp in names(comparisons)) {
  infile <- comparisons[[cmp]]
  if (!file.exists(infile)) {
    cat("[WARN] missing:", infile, "\n")
    next
  }

  res <- read.csv(infile, row.names = 1, check.names = FALSE)

  # 处理 NA
  if (!("padj" %in% colnames(res)) || !("log2FoldChange" %in% colnames(res))) {
    stop("File missing padj or log2FoldChange: ", infile)
  }
  res$padj[is.na(res$padj)] <- 1
  res$log2FoldChange[is.na(res$log2FoldChange)] <- 0

  sig <- res[res$padj < padj_cut & abs(res$log2FoldChange) >= lfc_cut, , drop=FALSE]
  up   <- sig[sig$log2FoldChange > 0, , drop=FALSE]
  down <- sig[sig$log2FoldChange < 0, , drop=FALSE]

  # 输出完整表
  write.csv(up,   file = sprintf("deseq2_out/Up_%s_padj%.2g_lfc%d.csv",   cmp, padj_cut, lfc_cut))
  write.csv(down, file = sprintf("deseq2_out/Down_%s_padj%.2g_lfc%d.csv", cmp, padj_cut, lfc_cut))

  # 输出基因ID列表（用于GO/KEGG）
  write.table(rownames(up),
              file = sprintf("deseq2_out/Up_%s_padj%.2g_lfc%d.genes.txt", cmp, padj_cut, lfc_cut),
              quote = FALSE, row.names = FALSE, col.names = FALSE)
  write.table(rownames(down),
              file = sprintf("deseq2_out/Down_%s_padj%.2g_lfc%d.genes.txt", cmp, padj_cut, lfc_cut),
              quote = FALSE, row.names = FALSE, col.names = FALSE)

  # 汇总统计
  summary_list[[cmp]] <- data.frame(
    comparison = cmp,
    total_genes = nrow(res),
    sig_genes   = nrow(sig),
    up_genes    = nrow(up),
    down_genes  = nrow(down)
  )

  cat("[OK]", cmp, "sig:", nrow(sig), "up:", nrow(up), "down:", nrow(down), "\n")
}

summary_df <- do.call(rbind, summary_list)
write.csv(summary_df, "deseq2_out/DEG_up_down_summary_padj0.05_lfc1.csv", row.names = FALSE)
cat("Done: deseq2_out/DEG_up_down_summary_padj0.05_lfc1.csv\n")
