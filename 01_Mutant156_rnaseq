# ===== 参数 =====
dds_rds <- "deseq2_out/dds.rds"
out_csv <- "deseq2_out/Expr_normcounts_with_DEGflags.csv"

padj_cut <- 0.05
lfc_cut  <- 1

# 清理ID用的后缀
clean_id <- function(x) sub("\\.Wm82\\.a4\\.v1$", "", x)

# ===== 读取dds，导出表达量 =====
dds <- readRDS(dds_rds)

raw_counts  <- counts(dds, normalized = FALSE)
norm_counts <- counts(dds, normalized = TRUE)

gene_id <- rownames(dds)

# 给表达量列加前缀，避免混淆
raw_df  <- as.data.frame(raw_counts)
colnames(raw_df) <- paste0("raw_", colnames(raw_df))

norm_df <- as.data.frame(norm_counts)
colnames(norm_df) <- paste0("norm_", colnames(norm_df))

out <- data.frame(
  Gene = gene_id,
  Gene_clean = clean_id(gene_id),
  raw_df,
  norm_df,
  stringsAsFactors = FALSE,
  check.names = FALSE
)

# ===== 定义要做的对比=====
comparisons <- list(
  M156big_vs_Wm82big    = c("M156_big",   "Wm82_big"),
  M156small_vs_Wm82big  = c("M156_small", "Wm82_big"),
  M156small_vs_M156big  = c("M156_small", "M156_big")
)

# ===== 把每个对比的统计量 + DEG标注 合并进总表 =====
for (cmp in names(comparisons)) {
  A <- comparisons[[cmp]][1]
  B <- comparisons[[cmp]][2]

  res <- results(dds, contrast = c("group", A, B))
  res_df <- as.data.frame(res)
  res_df$Gene <- rownames(res_df)

  # 处理NA
  res_df$padj[is.na(res_df$padj)] <- 1
  res_df$log2FoldChange[is.na(res_df$log2FoldChange)] <- 0
  res_df$pvalue[is.na(res_df$pvalue)] <- 1

  # DEG 标注
  res_df[[paste0(cmp, "_DEG")]] <- (res_df$padj < padj_cut & abs(res_df$log2FoldChange) >= lfc_cut)
  res_df[[paste0(cmp, "_Direction")]] <- ifelse(
    res_df[[paste0(cmp, "_DEG")]] & res_df$log2FoldChange > 0, "Up",
    ifelse(res_df[[paste0(cmp, "_DEG")]] & res_df$log2FoldChange < 0, "Down", "NS")
  )

  # 只保留需要的列，并加前缀避免冲突
  keep_cols <- c("Gene", "baseMean", "log2FoldChange", "lfcSE", "stat", "pvalue", "padj",
                 paste0(cmp, "_DEG"), paste0(cmp, "_Direction"))
  res_df <- res_df[, keep_cols, drop=FALSE]

  # 给统计列加对比名前缀
  colnames(res_df) <- ifelse(
    colnames(res_df) == "Gene" | grepl(paste0("^", cmp, "_"), colnames(res_df)),
    colnames(res_df),
    paste0(cmp, "_", colnames(res_df))
  )

  out <- merge(out, res_df, by = "Gene", all.x = TRUE, sort = FALSE)
}

write.csv(out, out_csv, row.names = FALSE)
cat("Done:", out_csv, "\n")
