# ========= 参数区 =========
in_dir  <- "enrich_out/GO"
out_dir <- file.path(in_dir, "facet_plots")
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)

topN <- 10
use_p_adjust_for_color <- FALSE   # TRUE: -log10(p.adjust)；FALSE: -log10(pvalue)
export_png <- TRUE
exclude_obsolete <- FALSE

# 字体大小/加粗
base_size <- 15
axis_text_size <- 11
strip_text_size <- 12
title_size <- 16

# 颜色：低蓝高红
low_col  <- "blue"
high_col <- "red"

# ========= 工具函数 =========
parse_ratio <- function(x) {
  sp <- strsplit(as.character(x), "/", fixed = TRUE)
  vapply(sp, function(z) as.numeric(z[1]) / as.numeric(z[2]), numeric(1))
}
clean_y_labels <- function(x) sub("\\|\\|.*$", "", x)

make_plot_one <- function(infile, outpdf, plot_title) {
  df <- read.csv(infile, check.names = FALSE)

  need_cols <- c("ID","Description","GeneRatio","Count","pvalue","p.adjust","ontology")
  miss <- setdiff(need_cols, colnames(df))
  if (length(miss) > 0) {
    message("[SKIP] missing cols: ", paste(miss, collapse=","), " in ", infile)
    return(invisible(FALSE))
  }

  df$GeneRatio_num <- parse_ratio(df$GeneRatio)
  score <- if (use_p_adjust_for_color) df$p.adjust else df$pvalue
  df$neglog10 <- -log10(score + 1e-300)

  df2 <- df %>%
    filter(ontology %in% c("BP","CC","MF")) %>%
    filter(!is.na(Description), Description != "") %>%
    { if (exclude_obsolete) filter(., !grepl("obsolete", Description, ignore.case = TRUE)) else . } %>%
    group_by(ontology) %>%
    arrange(p.adjust, pvalue) %>%   # 每个本体内按显著性取TopN
    slice_head(n = topN) %>%
    ungroup()

  if (nrow(df2) == 0) {
    message("[EMPTY] ", basename(infile))
    return(invisible(FALSE))
  }

  # facet标签换成全称
  df2$ontology <- factor(
    df2$ontology,
    levels = c("BP","CC","MF"),
    labels = c("Biological Process","Cellular Component","Molecular Function")
  )

  # 每个分面内部排序（这里按GeneRatio；也可改成按neglog10）
  df2 <- df2 %>%
    group_by(ontology) %>%
    arrange(GeneRatio_num, .by_group = TRUE) %>%
    mutate(term_facet = paste0(Description, "||", ontology)) %>%
    ungroup()

  df2$term_facet <- factor(df2$term_facet, levels = df2$term_facet)

  p <- ggplot(df2, aes(x = GeneRatio_num, y = term_facet)) +
    geom_point(aes(size = Count, color = neglog10)) +
    scale_color_gradient(low = low_col, high = high_col) +
    facet_grid(ontology ~ ., scales = "free_y", space = "free_y") +
    scale_y_discrete(labels = clean_y_labels) +
    labs(
      title = plot_title,
      x = "Gene Ratio",
      y = "GO Terms",
      color = if (use_p_adjust_for_color) "-log10(p.adjust)" else "-log10(pvalue)",
      size  = "Gene Count"
    ) +
    theme_bw(base_size = base_size) +
    theme(
      plot.title = element_text(hjust = 0.5, size = title_size, face = "bold"),
      axis.title = element_text(size = base_size, face = "bold"),
      axis.text  = element_text(size = axis_text_size, face = "bold"),
      strip.text.y = element_text(angle = 90, size = strip_text_size, face = "bold"),
      legend.title = element_text(face = "bold"),
      legend.text  = element_text(face = "bold")
    )

  ggsave(outpdf, p, width = 9, height = 10)

  if (export_png) {
    outpng <- sub("\\.pdf$", ".png", outpdf)
    ggsave(outpng, p, width = 9, height = 10, dpi = 300)
  }

  invisible(TRUE)
}

# ========= 批量处理 =========
