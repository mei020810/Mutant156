read_abundance_one <- function(file, sample_name) {
  dt <- fread(file, sep = "\t", header = TRUE, check.names = FALSE)

  # 兼容列名
  gene_col <- if ("Gene ID" %in% names(dt)) "Gene ID" else names(dt)[grepl("^Gene", names(dt))][1]
  fpkm_col <- if ("FPKM" %in% names(dt)) "FPKM" else names(dt)[toupper(names(dt)) == "FPKM"][1]
  tpm_col  <- if ("TPM"  %in% names(dt)) "TPM"  else names(dt)[toupper(names(dt)) == "TPM"][1]

  if (is.na(gene_col) || is.na(fpkm_col) || is.na(tpm_col)) {
    stop("Cannot find Gene ID / FPKM / TPM columns in: ", file)
  }

  dt2 <- dt[, .(
    Gene = get(gene_col),
    tmp_FPKM = as.numeric(get(fpkm_col)),
    tmp_TPM  = as.numeric(get(tpm_col))
  )]

  setnames(dt2, c("tmp_FPKM", "tmp_TPM"), c(paste0("FPKM_", sample_name), paste0("TPM_", sample_name)))
  dt2
}

