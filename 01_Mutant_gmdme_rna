  df2 <- bind_rows(pos, neg) %>%
    mutate(Direction = ifelse(NES > 0, "Gmdme_side", "Wm82_side"))

  if (nrow(df2) == 0) {
    message("[EMPTY] no selected terms in ", infile)
    return(invisible(NULL))
  }

  summary_rows <- list()
  long_rows <- list()

  for (i in seq_len(nrow(df2))) {
    term_id   <- df2$ID[i]
    term_desc <- df2$Description[i]
    direction <- df2$Direction[i]
    nes       <- df2$NES[i]
    padj      <- df2$p.adjust[i]

    genes <- unique(strsplit(df2$core_enrichment[i], "/", fixed = TRUE)[[1]])
    genes <- genes[genes != ""]

    summary_rows[[i]] <- data.frame(
      Category = prefix,
      ID = term_id,
      Description = term_desc,
      Direction = direction,
      NES = nes,
      p.adjust = padj,
      Core_gene_count = length(genes),
      Core_genes = paste(genes, collapse = ";"),
      stringsAsFactors = FALSE
    )

    if (length(genes) > 0) {
      long_rows[[i]] <- data.frame(
        Category = prefix,
        ID = term_id,
        Description = term_desc,
        Direction = direction,
        NES = nes,
        p.adjust = padj,
        Gene = genes,
        stringsAsFactors = FALSE
      )
    }

    out_name <- paste0(
      prefix, "_",
      direction, "_",
      safe_name(term_desc),
      ".genes.txt"
    )

    write.table(
      genes,
      file = file.path("gsea_out/summary_plot_core_genes", out_name),
      quote = FALSE, row.names = FALSE, col.names = FALSE
    )
  }

  summary_df <- bind_rows(summary_rows)
  write.csv(
    summary_df,
    file = file.path("gsea_out/summary_plot_core_genes", paste0(prefix, "_summary_plot_core_genes.csv")),
    row.names = FALSE
  )

  if (length(long_rows) > 0) {
    long_df <- bind_rows(long_rows)
    write.csv(
      long_df,
      file = file.path("gsea_out/summary_plot_core_genes", paste0(prefix, "_summary_plot_core_genes_long.csv")),
      row.names = FALSE
    )
  }
}

export_summary_plot_core_genes(
  "gsea_out/GO_GSEA_all.csv",
  "GO_GSEA"
)

export_summary_plot_core_genes(
  "gsea_out/KEGG_GSEA_all.csv",
  "KEGG_GSEA"
)

cat("Done. Files written to gsea_out/summary_plot_core_genes/\n")
