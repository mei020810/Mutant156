    prefix    = set_name,
    subdir    = "GO"
  )

  # -------- GO split BP/CC/MF (基于表里的Level) --------
  if (!is.null(eg_go)) {
    go_res <- as.data.frame(eg_go) %>%
      left_join(go_term2name, by=c("ID"="term"))
    write.csv(go_res, file.path(outdir, "GO", paste0(set_name, ".with_ontology.csv")), row.names=FALSE)

    for (ont in c("BP","CC","MF")) {
      sub <- go_res %>% filter(ontology==ont)
      if (nrow(sub)==0) next
      write.csv(sub, file.path(outdir, "GO", paste0(set_name, ".", ont, ".csv")), row.names=FALSE)
    }
  }

  # -------- KEGG Pathway --------
  run_enrich(
    genes     = genes,
    universe  = bg_kegg_pw,
    term2gene = kegg_pw_term2gene,
    term2name = kegg_pw_term2name,
    prefix    = set_name,
    subdir    = "KEGG_Pathway"
  )

  # -------- (可选) KEGG KO --------
  if (do_kegg_ko) {
    run_enrich(
      genes     = genes,
      universe  = bg_kegg_ko,
      term2gene = kegg_ko_term2gene,
      term2name = kegg_ko_term2name,
      prefix    = set_name,
      subdir    = "KEGG_KO"
    )
  }
}
