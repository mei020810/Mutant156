# ===================== enrichment runner =====================
run_enrich <- function(genes, universe, term2gene, term2name, prefix, subdir){
  od <- file.path(outdir, subdir)
  dir.create(od, showWarnings=FALSE, recursive=TRUE)

  genes <- unique(genes)
  genes <- intersect(genes, universe)

  if (length(genes) < 5) {
    message("[SKIP] ", prefix, " genes < 5 after intersect universe")
    return(NULL)
  }

  eg <- enricher(
    gene          = genes,
    universe      = universe,
    TERM2GENE     = term2gene,
    TERM2NAME     = term2name,
    pAdjustMethod = "BH",
    pvalueCutoff  = 0.05,
    qvalueCutoff  = 0.05,
    minGSSize     = 10,
    maxGSSize     = 500
  )

  if (is.null(eg) || nrow(as.data.frame(eg))==0) {
    message("[EMPTY] ", prefix)
    return(NULL)
  }

  res <- as.data.frame(eg)
  write.csv(res, file.path(od, paste0(prefix, ".enrich.csv")), row.names=FALSE)

  pdf(file.path(od, paste0(prefix, ".dotplot.pdf")), width=9, height=6)
  print(dotplot(eg, showCategory=10))
  dev.off()

  pdf(file.path(od, paste0(prefix, ".barplot.pdf")), width=9, height=6)
  print(barplot(eg, showCategory=10))
  dev.off()

  return(eg)
}

