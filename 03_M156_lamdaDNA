cat > 04_lambda_extract_report.sh <<'EOF'
#!/bin/bash
set -euo pipefail
THREADS=25
BUFFER_SIZE="50G"
COV_THRESHOLD=1
LAMBDA_INDEX="/data/mshe/Mutant_dnamethylationdata/lambda_index"
OUTBASE="/data/mshe/Mutant_dnamethylationdata/03.lambda"
LOGDIR="/data/mshe/Mutant_dnamethylationdata/logs"
mkdir -p "$LOGDIR"

SAMPLES=(156_big_1 156_big_2 156_small_1 156_small_2 W82_1 W82_2)
EXTRACT_CORE_OPT="--multicore"
for s in "${SAMPLES[@]}"; do
  echo "=== lambda extractor+report: $s $(date) ==="
  out="$OUTBASE/lambda_${s}"

  BAM=$(ls -1 "$out"/*deduplicated.bam | head -n 1)

  bismark_methylation_extractor \
    --paired-end \
    --ignore 2 --ignore_r2 2 \
    --buffer_size "$BUFFER_SIZE" \
    --CX_context \
    --cutoff "$COV_THRESHOLD" \
    --comprehensive \
    --bedGraph --gzip \
    $EXTRACT_CORE_OPT "$THREADS" \
    --genome_folder "$LAMBDA_INDEX" \
    --output "$out" \
    "$BAM" \
    2> "${LOGDIR}/${s}.lambda.extractor.log"

  COV=$(ls -1 "$out"/*.bismark.cov.gz | head -n 1)

  coverage2cytosine \
    "$COV" \
    --dir "$out" \
    --CX_context \
    -o "${s}" \
    --genome_folder "$LAMBDA_INDEX" \
    --coverage_threshold "$COV_THRESHOLD" \
    2> "${LOGDIR}/${s}.lambda.coverage2cytosine.log"

  # 转化率：未甲基化reads / (甲基化reads+未甲基化reads) × 100%
  echo -n "${s} lambda conversion rate: "
  zcat "$COV" | awk '{meth+=$5; unmeth+=$6} END{ if(meth+unmeth>0) printf "%.3f%%\n", unmeth/(meth+unmeth)*100; else print "NA" }'
done
EOF

