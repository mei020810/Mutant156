cat > 03_chloroplast_align_dedup_extract_report.sh <<'EOF'
#!/bin/bash
set -euo pipefail
ALIGN_THREADS=4
EXTRACT_THREADS=4
BUFFER_SIZE="20G"
COV_THRESHOLD=1
CHLO_INDEX="/data/mshe/Mutant_dnamethylationdata/chloroplast_index"
TRIMDIR="/data/mshe/Mutant_dnamethylationdata/trimmed_results"
OUTBASE="/data/mshe/Mutant_dnamethylationdata/03.chloroplast"
LOGDIR="/data/mshe/Mutant_dnamethylationdata/logs"
mkdir -p "$OUTBASE" "$LOGDIR"

SAMPLES=(156_big_1 156_big_2 156_small_1 156_small_2 W82_1 W82_2)

EXTRACT_CORE_OPT="--multicore"
if ! bismark_methylation_extractor --help 2>&1 | grep -q -- '--multicore'; then
  EXTRACT_CORE_OPT="--parallel"
fi

# 1) 先完成所有样本的比对 + 去重
for s in "${SAMPLES[@]}"; do
  echo "=== chloroplast align+dedup: $s $(date) ==="
  out="$OUTBASE/${s}"
  mkdir -p "$out"

  R1="${TRIMDIR}/${s}_1_val_1.fq.gz"
  R2="${TRIMDIR}/${s}_2_val_2.fq.gz"

  bismark \
    --parallel ${ALIGN_THREADS} \
    --output_dir "$out" \
    --gzip \
    "$CHLO_INDEX" \
    -1 "$R1" -2 "$R2" \
    2> "${LOGDIR}/${s}.chloroplast.bismark.log"

  deduplicate_bismark \
    --paired --bam \
    "$out/"*_bismark_bt2_pe.bam \
    --output_dir "$out" \
    2> "${LOGDIR}/${s}.chloroplast.dedup.log"
done

if ls "$out"/*deduplicated.bam >/dev/null 2>&1; then
  echo "[SKIP] $s deduplicated bam already exists"
  continue
fi

# 2) 再完成所有样本的提取 + CX report
for s in "${SAMPLES[@]}"; do
  echo "=== chloroplast extractor+report: $s $(date) ==="
  out="$OUTBASE/${s}"

  BAM=$(ls -1 "$out"/*deduplicated.bam | head -n 1)

  bismark_methylation_extractor \
    --paired-end \
    --ignore 2 --ignore_r2 2 \
    --buffer_size "$BUFFER_SIZE" \
    --CX_context \
    --cutoff "$COV_THRESHOLD" \
    --comprehensive \
    --bedGraph --gzip \
    $EXTRACT_CORE_OPT "$EXTRACT_THREADS" \
    --genome_folder "$CHLO_INDEX" \
    --output "$out" \
    "$BAM" \
    2> "${LOGDIR}/${s}.chloroplast.extractor.log"

  COV=$(ls -1 "$out"/*.bismark.cov.gz | head -n 1)

  coverage2cytosine \
    "$COV" \
    --dir "$out" \
    --CX_context \
    -o "${s}" \
    --genome_folder "$CHLO_INDEX" \
    --coverage_threshold "$COV_THRESHOLD" \
    2> "${LOGDIR}/${s}.chloroplast.coverage2cytosine.log"

  echo -n "${s} chloroplast conversion rate: "
  zcat "$COV" | awk '{meth+=$5; unmeth+=$6} END{ if(meth+unmeth>0) printf "%.3f%%\n", unmeth/(meth+unmeth)*100; else print "NA" }'
done
EOF

