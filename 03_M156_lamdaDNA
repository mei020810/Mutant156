#!/bin/bash
set -euo pipefail
THREADS=25
LAMBDA_INDEX="/data/mshe/Mutant_dnamethylationdata/lambda_index"
TRIMDIR="/data/mshe/Mutant_dnamethylationdata/trimmed_results"
OUTBASE="/data/mshe/Mutant_dnamethylationdata/03.lambda"
LOGDIR="/data/mshe/Mutant_dnamethylationdata/logs"
mkdir -p "$OUTBASE" "$LOGDIR"

SAMPLES=(156_big_1 156_big_2 156_small_1 156_small_2 W82_1 W82_2)

for s in "${SAMPLES[@]}"; do
  echo "=== lambda align+dedup: $s $(date) ==="
  out="$OUTBASE/lambda_${s}"
  mkdir -p "$out"

  R1="${TRIMDIR}/${s}_1_val_1.fq.gz"
  R2="${TRIMDIR}/${s}_2_val_2.fq.gz"

  bismark \
    --parallel ${THREADS} \
    --output_dir "$out" \
    --gzip \
    "$LAMBDA_INDEX" \
    -1 "$R1" -2 "$R2" \
    2> "${LOGDIR}/${s}.lambda.bismark.log"

  deduplicate_bismark \
    --paired --bam \
    "$out/"*_bismark_bt2_pe.bam \
    --output_dir "$out" \
    2> "${LOGDIR}/${s}.lambda.dedup.log"
done
EOF

